{
  // 【必填】钉钉机器人 Webhook 地址
  // 获取方式：钉钉群 > 群设置 > 智能群助手 > 添加机器人 > 自定义
  // 示例："https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN"
  // 安全设置：建议选择"自定义关键词"，填写 "AnyRouter" 或 "签到" 等通知内容
  "webhook": "",

  // 【可选】平台特定设置
  "platform_settings": {
    // 消息类型：markdown | 其他（纯文本）
    "message_type": "",
  },

  // 【可选】自定义通知模板（不设置，或为空时使用下方默认模板）
  "template": {
    // 通知标题，不设置，或为空字符串时不展示
    "title": "{% if has_balance_changed %}AnyRouter 签到与额度变动提醒{% else %}AnyRouter 签到提醒{% endif %}",

    // 通知内容
    "content": "{# 钉钉通知模板 #}{% if timestamp %}⏰ 执行时间：{{ timestamp }}{% if timezone %} {{ timezone }}{% endif %}\n\n{% endif %}{% if success_accounts %}✅ 签到成功账号\n{% for account in success_accounts %}• {{ account.name }}\n💰 当前额度：${{ account.quota }}，已使用：${{ account.used }}\n\n{% endfor %}{% endif %}{% if quota_changed_accounts %}💹 总额度发生变化\n{% for account in quota_changed_accounts %}• {{ account.name }}\n额度变化：{{ account.quota_delta_display }}\n变动前：${{ account.prev_quota }} → 当前：${{ account.quota }}\n\n{% endfor %}{% endif %}{% if used_changed_accounts %}📈 已使用额度发生变化\n{% for account in used_changed_accounts %}• {{ account.name }}\n已用变化：{{ account.used_delta_display }}\n变动前：${{ account.prev_used }} → 当前：${{ account.used }}\n\n{% endfor %}{% endif %}{% if failed_accounts %}❌ 失败账号\n{% for account in failed_accounts %}• {{ account.name }}：{{ account.error }}\n{% endfor %}\n{% endif %}📊 签到结果统计\n✅ 成功：{{ stats.success_count }}/{{ stats.total_count }}\n❌ 失败：{{ stats.failed_count }}/{{ stats.total_count }}\n{% if all_success %}🎉 全部账号签到成功！{% else %}{% if partial_success %}⚠️ 部分账号签到成功{% else %}🚫 全部账号签到失败{% endif %}{% endif %}",
  },
}
