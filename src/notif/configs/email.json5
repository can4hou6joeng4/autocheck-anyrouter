{
  // 【必填】SMTP 登录用户（通常是邮箱地址）
  "user": "",

  // 【必填】SMTP 登录密码或授权码
  "pass": "",

  // 【必填】收件人邮箱地址
  "to": "",

  // 【可选】发件人地址
  // 如不指定，使用 user 作为发件人地址
  // 用于 SMTP 登录用户与发件人地址不同的场景（如 Resend 服务）
  "sender": "",

  // 【可选】自定义 SMTP 服务器地址
  // 如不指定，会根据邮箱自动推断
  "smtp_server": "",

  // 【可选】平台特定设置
  "platform_settings": {
    // 消息类型（'plain' 或 'html'）
    // 如不指定，会根据内容自动检测
    "message_type": "",
  },

  // 【可选】自定义通知模板（不设置，或为空时使用下方默认模板）
  "template": {
    // 通知标题，不设置，或为空字符串时不展示
    "title": "{% if has_balance_changed %}AnyRouter 签到与额度变动提醒{% else %}AnyRouter 签到提醒{% endif %}",

    // 通知内容
    "content": "{# 邮箱通知模板 #}{% if timestamp %}⏰ 执行时间：{{ timestamp }}{% if timezone %} {{ timezone }}{% endif %}\n\n{% endif %}{% if success_accounts %}✅ 签到成功账号\n{% for account in success_accounts %}• {{ account.name }}\n💰 当前额度：${{ account.quota }}，已使用：${{ account.used }}\n\n{% endfor %}{% endif %}{% if quota_changed_accounts %}💹 总额度发生变化\n{% for account in quota_changed_accounts %}• {{ account.name }}\n额度变化：{{ account.quota_delta_display }}\n变动前：${{ account.prev_quota }} → 当前：${{ account.quota }}\n\n{% endfor %}{% endif %}{% if used_changed_accounts %}📈 已使用额度发生变化\n{% for account in used_changed_accounts %}• {{ account.name }}\n已用变化：{{ account.used_delta_display }}\n变动前：${{ account.prev_used }} → 当前：${{ account.used }}\n\n{% endfor %}{% endif %}{% if failed_accounts %}❌ 失败账号\n{% for account in failed_accounts %}• {{ account.name }}：{{ account.error }}\n{% endfor %}\n{% endif %}📊 签到结果统计\n✅ 成功：{{ stats.success_count }}/{{ stats.total_count }}\n❌ 失败：{{ stats.failed_count }}/{{ stats.total_count }}\n{% if all_success %}🎉 全部账号签到成功！{% else %}{% if partial_success %}⚠️ 部分账号签到成功{% else %}🚫 全部账号签到失败{% endif %}{% endif %}",
  },
}
