{
  // 【必填】飞书机器人 Webhook 地址
  // 示例："https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN"
  // 安全设置：建议选择"关键词"，填写 "AnyRouter" 或 "签到" 等通知内容
  "webhook": "",

  // 【可选】平台特定设置
  "platform_settings": {
    // 消息类型：card（卡片 json 1.0）| card_v2（卡片 json 2.0）| 其他（纯文本）
    "message_type": "card",

    // 卡片颜色主题：`message_type` 为 `card` 或 `card_v2` 时生效
    // 支持静态颜色（blue/green/red/orange/purple/grey）或 stencil 动态模板
    // 留空则默认根据签到结果自动选择（全部成功=绿色，部分成功=橙色，全部失败=红色）
    "color_theme": "",
  },

  // 【可选】自定义通知模板（不设置，或为空时使用下方默认模板）
  "template": {
    // 通知标题，不设置，或为空字符串时不展示
    "title": "{% if has_balance_changed %}AnyRouter 签到与额度变动提醒{% else %}AnyRouter 签到提醒{% endif %}",

    // 通知内容
    "content": "{# 飞书通知模板 #}{% if timestamp %}**⏰ 执行时间**\n{{ timestamp }}{% if timezone %} {{ timezone }}{% endif %}\n\n{% endif %}{% if success_accounts %}**✅ 签到成功账号**\n{% for account in success_accounts %}**• {{ account.name }}**\n当前额度：${{ account.quota }}，已使用：${{ account.used }}\n\n{% endfor %}{% endif %}{% if quota_changed_accounts %}**💹 总额度发生变化**\n{% for account in quota_changed_accounts %}**• {{ account.name }}**\n额度变化：{{ account.quota_delta_display }}\n变动前：${{ account.prev_quota }} → 当前：${{ account.quota }}\n\n{% endfor %}{% endif %}{% if used_changed_accounts %}**📈 已使用额度发生变化**\n{% for account in used_changed_accounts %}**• {{ account.name }}**\n已用变化：{{ account.used_delta_display }}\n变动前：${{ account.prev_used }} → 当前：${{ account.used }}\n\n{% endfor %}{% endif %}{% if failed_accounts %}**❌ 失败账号**\n{% for account in failed_accounts %}• {{ account.name }}：{{ account.error }}\n{% endfor %}\n{% endif %}**📊 签到结果统计**\n✅ 成功：{{ stats.success_count }}/{{ stats.total_count }}\n❌ 失败：{{ stats.failed_count }}/{{ stats.total_count }}\n{% if all_success %}**🎉 全部账号签到成功！**{% else %}{% if partial_success %}**⚠️ 部分账号签到成功**{% else %}**🚫 全部账号签到失败**{% endif %}{% endif %}",
  },
}
